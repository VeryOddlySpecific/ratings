{
  "_comment": "VOS (VOS Optimized Score) Configuration v2.0",
  "_comment_2": "All rating inputs are expected on the 20-80 scale",
  "_comment_3": "Tool weights within each category should sum to 1.0 for clarity",
  
  "hitters": {
    "tool_categories": {
      "_comment": "Weights for each tool within its category (should sum to ~1.0)",
      
      "batting": {
        "_comment": "Contact (Gap/Ks) is king in OOTP. Eye matters more than raw power for most positions.",
        "Gap": 0.20,
        "Pow": 0.20,
        "Eye": 0.35,
        "Ks": 0.25
      },
      
      "defense": {
        "_comment": "Position-specific defensive tool weights",
        "C": {
          "_comment": "Catchers: Arm is most important, then framing, then blocking",
          "CArm": 0.45,
          "CFrm": 0.30,
          "CBlk": 0.25
        },
        "1B": {
          "_comment": "1B: Error avoidance is everything, range barely matters",
          "IFE": 0.80,
          "IFA": 0.20,
          "IFR": 0.0,
          "TDP": 0.0
        },
        "2B": {
          "_comment": "2B: Range and turn DP are critical, arm less so",
          "IFR": 0.40,
          "TDP": 0.35,
          "IFE": 0.20,
          "IFA": 0.05
        },
        "3B": {
          "_comment": "3B: Arm is king, then range, then error avoidance",
          "IFA": 0.50,
          "IFR": 0.30,
          "IFE": 0.20,
          "TDP": 0.0
        },
        "SS": {
          "_comment": "SS: Range is paramount, then turn DP, then error/arm",
          "IFR": 0.50,
          "TDP": 0.30,
          "IFE": 0.15,
          "IFA": 0.05
        },
        "LF": {
          "_comment": "LF: Range most important, arm less critical",
          "OFR": 0.50,
          "OFE": 0.35,
          "OFA": 0.15
        },
        "CF": {
          "_comment": "CF: Range is everything, error avoidance second",
          "OFR": 0.70,
          "OFE": 0.25,
          "OFA": 0.05
        },
        "RF": {
          "_comment": "RF: Arm matters most, then range",
          "OFA": 0.50,
          "OFR": 0.30,
          "OFE": 0.20
        }
      },
      
      "baserunning": {
        "_comment": "Speed and baserunning instinct matter most. Steal rating is situational.",
        "Speed": 0.40,
        "Run": 0.35,
        "StealAbi": 0.20,
        "StlRt": 0.05
      }
    },
    
    "position_category_weights": {
      "_comment": "How much each position values batting/defense/baserunning (should sum to ~1.0)",
      "_comment_2": "These reflect positional scarcity and defensive importance",
      
      "C": {
        "batting": 0.25,
        "defense": 0.70,
        "baserunning": 0.05
      },
      "1B": {
        "_comment": "1B is almost pure offense - you need a bat to justify the position",
        "batting": 0.85,
        "defense": 0.10,
        "baserunning": 0.05
      },
      "2B": {
        "batting": 0.45,
        "defense": 0.45,
        "baserunning": 0.10
      },
      "3B": {
        "batting": 0.50,
        "defense": 0.45,
        "baserunning": 0.05
      },
      "SS": {
        "_comment": "SS is premium defense, but modern SS need some bat",
        "batting": 0.30,
        "defense": 0.60,
        "baserunning": 0.10
      },
      "LF": {
        "batting": 0.75,
        "defense": 0.15,
        "baserunning": 0.10
      },
      "CF": {
        "_comment": "CF needs elite defense, but bat still matters",
        "batting": 0.30,
        "defense": 0.65,
        "baserunning": 0.05
      },
      "RF": {
        "batting": 0.75,
        "defense": 0.15,
        "baserunning": 0.10
      },
      "DH": {
        "_comment": "DH is pure bat",
        "batting": 1.0,
        "defense": 0.0,
        "baserunning": 0.0
      }
    },
    
    "positional_standards": {
      "_comment": "Minimum expected ratings at each position to avoid penalties",
      "_comment_2": "Used to determine if a player is truly viable at a position",
      
      "C": {
        "CArm": 40,
        "CFrm": 35
      },
      "1B": {
        "IFE": 40
      },
      "2B": {
        "IFR": 40,
        "TDP": 40
      },
      "3B": {
        "IFA": 50,
        "IFR": 40
      },
      "SS": {
        "_comment": "SS has the highest defensive standards",
        "IFR": 60,
        "TDP": 50,
        "IFE": 50
      },
      "LF": {
        "OFR": 40
      },
      "CF": {
        "OFR": 55
      },
      "RF": {
        "OFA": 45
      }
    }
  },
  
  "pitchers": {
    "ability_weights": {
      "_comment": "Weights for pitch ability ratings (should sum to 1.0)",
      
      "SP": {
        "_comment": "SPs: Movement and Control are king. Stuff matters but less than you think.",
        "Stuff": 0.20,
        "Movement": 0.35,
        "Control": 0.35,
        "HR_Avoid": 0.10
      },
      "RP": {
        "_comment": "RPs: Stuff becomes more important, control less critical in short bursts",
        "Stuff": 0.45,
        "Movement": 0.30,
        "Control": 0.15,
        "HR_Avoid": 0.10
      }
    },
    
    "arsenal_evaluation": {
      "_comment": "How to evaluate pitch arsenal quality and diversity",
      
      "pitch_type_values": {
        "_comment": "Relative value of each pitch type (normalized to Fastball = 1.0)",
        "Fastball": 1.0,
        "Sinker": 0.95,
        "Cutter": 0.90,
        "Slider": 0.95,
        "Curve": 0.90,
        "Changeup": 0.90,
        "Splitter": 0.85,
        "Forkball": 0.75,
        "Circle_Change": 0.90,
        "Screwball": 0.65,
        "Knuckle_Curve": 0.70,
        "Knuckleball": 0.60
      },
      
      "pitch_slot_weights": {
        "_comment": "How much each pitch in a pitcher's arsenal matters",
        "SP": {
          "_comment": "SP needs 3-4 quality pitches with declining importance",
          "primary": 0.40,
          "secondary": 0.30,
          "tertiary": 0.20,
          "quaternary": 0.10
        },
        "RP": {
          "_comment": "RP can survive on 2-3 pitches, primary pitch is critical",
          "primary": 0.55,
          "secondary": 0.30,
          "tertiary": 0.15
        }
      },
      
      "diversity_requirements": {
        "_comment": "Arsenal composition requirements for optimal scoring",
        "SP": {
          "min_pitches": 3,
          "optimal_pitches": 4,
          "min_velocity_tiers": 2,
          "min_break_planes": 2
        },
        "RP": {
          "min_pitches": 2,
          "optimal_pitches": 3,
          "min_velocity_tiers": 2,
          "min_break_planes": 1
        }
      },
      
      "diversity_modifiers": {
        "_comment": "Bonuses/penalties for arsenal construction",
        "velocity_tier_bonus": 1.5,
        "break_plane_bonus": 1.5,
        "insufficient_pitches_penalty": -3.0
      }
    },
    
    "role_balance": {
      "_comment": "How to weight ability vs arsenal for each role",
      "SP": {
        "ability_weight": 0.80,
        "arsenal_weight": 0.20
      },
      "RP": {
        "_comment": "RPs lean slightly more on arsenal (2-3 great pitches)",
        "ability_weight": 0.75,
        "arsenal_weight": 0.25
      }
    },
    
    "stamina_requirements": {
      "_comment": "Stamina penalties for starters who can't go deep",
      "SP": {
        "minimum_stamina": 50,
        "penalty_per_point_below": 0.5
      }
    }
  },
  
  "adjustments": {
    "_comment": "Contextual adjustments that apply to final scores",
    
    "development_trajectory": {
      "_comment": "Bonus/penalty based on current performance vs potential",
      "_comment_2": "Ratio = (avg current ratings) / (avg potential ratings)",
      
      "hitter": {
        "thresholds": {
          "exceeding_potential": 0.85,
          "meeting_potential": 0.70,
          "developing_normally": 0.50,
          "underperforming": 0.50
        },
        "modifiers": {
          "exceeding_potential": 2.0,
          "meeting_potential": 1.0,
          "developing_normally": 0.0,
          "underperforming": -2.0
        },
        "minimum_potential_for_bonus": 45
      },
      
      "pitcher": {
        "thresholds": {
          "exceeding_potential": 0.85,
          "meeting_potential": 0.70,
          "developing_normally": 0.50,
          "underperforming": 0.50
        },
        "modifiers": {
          "exceeding_potential": 2.0,
          "meeting_potential": 1.0,
          "developing_normally": 0.0,
          "underperforming": -2.0
        },
        "minimum_potential_for_bonus": 45
      }
    },
    
    "age_vs_level": {
      "_comment": "Adjustment for players ahead/behind the curve for their level",
      
      "hitter": {
        "level_targets": {
          "ML": { "target_age": 27, "tolerance_band": 2.5 },
          "AAA": { "target_age": 26, "tolerance_band": 2.0 },
          "AA": { "target_age": 24, "tolerance_band": 1.5 },
          "A+": { "target_age": 22, "tolerance_band": 1.5 },
          "A": { "target_age": 21, "tolerance_band": 1.2 },
          "A-": { "target_age": 20, "tolerance_band": 1.0 },
          "Rookie": { "target_age": 19, "tolerance_band": 0.8 }
        },
        "max_bonus": 3.0,
        "max_penalty": -3.0
      },
      
      "pitcher": {
        "_comment": "Pitchers develop slower, targets are ~1 year older",
        "level_targets": {
          "ML": { "target_age": 28, "tolerance_band": 2.5 },
          "AAA": { "target_age": 27, "tolerance_band": 2.0 },
          "AA": { "target_age": 25, "tolerance_band": 1.5 },
          "A+": { "target_age": 23, "tolerance_band": 1.5 },
          "A": { "target_age": 22, "tolerance_band": 1.2 },
          "A-": { "target_age": 21, "tolerance_band": 1.0 },
          "Rookie": { "target_age": 20, "tolerance_band": 0.8 }
        },
        "max_bonus": 2.5,
        "max_penalty": -3.0
      }
    },
    
    "personality_impact": {
      "_comment": "Personality cells in CSV are U (unknown), H (high), N (normal), L (low). U = no modifier.",
      "trait_modifiers": {
        "Intelligence": {
          "high": 1.5,
          "normal": 0.0,
          "low": -1.0
        },
        "Work_Ethic": {
          "high": 2.0,
          "normal": 0.0,
          "low": -2.0
        },
        "Greed": {
          "_comment": "Greed is slightly negative when high (harder to sign/extend)",
          "high": -1.0,
          "normal": 0.0,
          "low": 0.5
        },
        "Loyalty": {
          "high": 0.5,
          "normal": 0.0,
          "low": -0.5
        },
        "Leadership": {
          "high": 1.0,
          "normal": 0.0,
          "low": -0.5
        }
      }
    }
  },
  
  "normalization": {
    "_comment": "Settings for normalizing raw scores to the 20-80 scale",
    
    "method": "sigmoid",
    "target_center": 50.0,
    "scale_parameter": 15.0,
    "hard_floor": 20.0,
    "hard_ceiling": 80.0
  }
}
